# Copy this to .env and fill in your keys
ANTHROPIC_API_KEY=sk-ant-...

# Hugging Face Hub repo where model checkpoints are stored.
# Set this in Railway env vars so the server downloads checkpoints at startup.
# Upload once: huggingface-cli upload <HF_REPO_ID> model/checkpoints/ model/checkpoints/
HF_REPO_ID=jessicafan3ck/tactical-world-model
HF_TOKEN=  # only needed for private repos
